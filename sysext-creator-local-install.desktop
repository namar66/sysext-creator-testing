[Desktop Entry]
Type=Service
ServiceTypes=KonqPopupMenu/Plugin
MimeType=application/x-rpm;
Actions=installAsSysext;
X-KDE-Priority=TopLevel
Icon=sysext-creator

[Desktop Action installAsSysext]
Name=Install as System Extension
Name[cs]=Instalovat jako System Extension
Icon=system-software-install
Exec=konsole --hold -e bash -c "sysext-cli install '%f'; echo -e '\n✨ Done! Press any key to close...'; read -n 1"
